# ============================================================================
# ZAPLY PRODUCTION NGINX CONFIGURATION FOR CLEAN URL SPA
# Domain: zaply.in.net
# Purpose: Serve Flutter Web SPA with clean path-based routing
# ============================================================================
# 
# KEY FEATURES:
# - Clean URL routing (no # symbols): /auth, /chats, /settings, etc.
# - SPA fallback: Unknown routes serve index.html (Flutter handles routing)
# - Static asset caching: Aggressive 1-year cache for hashed filenames
# - API proxy: Backend API under /api/ namespace
# - WebSocket support: /ws/ for real-time messaging
# - Security headers: HSTS, CSP, X-Frame-Options, etc.
# - SEO optimization: robots.txt and sitemap.xml served with proper headers
# 
# ============================================================================

worker_processes auto;

events {
    worker_connections 1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    # DNS resolver for Docker containers (if using Docker)
    resolver 127.0.0.11 valid=30s;

    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout 65;
    types_hash_max_size 2048;

    server_tokens off;

    # ========================================================================
    # CONNECTION UPGRADE MAPPING - Handle WebSocket vs HTTP requests
    # ========================================================================
    # Maps $http_upgrade to $connection_upgrade:
    # - If request is a WebSocket upgrade: Connection header = "upgrade"
    # - Otherwise (normal HTTP requests): Connection header = "close"
    map $http_upgrade $connection_upgrade {
        default "upgrade";
        "" "close";
    }

    # ========================================================================
    # GZIP COMPRESSION - Reduce bandwidth usage
    # ========================================================================
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css text/xml text/javascript application/javascript application/json application/xml image/svg+xml;

    # ========================================================================
    # UPSTREAM SERVICES - Define backend connections
    # ========================================================================
    
    # Frontend Flutter Web SPA container
    upstream frontend_upstream {
        server frontend:80;
        keepalive 32;
    }

    # Backend FastAPI server
    upstream backend_upstream {
        server backend:8000;
        keepalive 32;
    }

    # ========================================================================
    # HTTP SERVER BLOCK - Redirect all HTTP to HTTPS
    # ========================================================================
    server {
        listen 80 default_server;
        server_name zaply.in.net www.zaply.in.net;

        # Health check endpoint (HTTP) - for load balancers
        location = /health {
            access_log off;
            add_header Content-Type text/plain;
            return 200 "healthy\n";
        }

        # Serve robots.txt over HTTP for SEO crawlers
        location = /robots.txt {
            root /var/www/html;
            add_header Content-Type "text/plain; charset=utf-8" always;
            add_header Cache-Control "public, max-age=86400" always;
            access_log off;
            try_files $uri =404;
        }

        # Serve sitemap.xml over HTTP for SEO crawlers
        location = /sitemap.xml {
            root /var/www/html;
            add_header Content-Type "application/xml; charset=utf-8" always;
            add_header Cache-Control "public, max-age=604800" always;
            access_log off;
            try_files $uri =404;
        }

        # Redirect all other HTTP traffic to HTTPS
        location / {
            return 301 https://$server_name$request_uri;
        }
    }

    # ========================================================================
    # HTTPS SERVER BLOCK - Main application server
    # ========================================================================
    server {
        listen 443 ssl http2 default_server;
        server_name zaply.in.net www.zaply.in.net;

        # ====================================================================
        # SSL/TLS CONFIGURATION
        # ====================================================================
        ssl_certificate /etc/letsencrypt/live/zaply.in.net/fullchain.pem;
        ssl_certificate_key /etc/letsencrypt/live/zaply.in.net/privkey.pem;
        
        # Modern SSL/TLS settings
        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_ciphers ECDHE-RSA-AES128-GCM-SHA256:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-RSA-AES128-SHA256:ECDHE-RSA-AES256-SHA384;
        ssl_prefer_server_ciphers off;
        ssl_session_cache shared:SSL:10m;
        ssl_session_timeout 10m;

        # HSTS - Force HTTPS for future requests
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

        # ====================================================================
        # SECURITY HEADERS - Applied to all responses
        # ====================================================================
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "SAMEORIGIN" always;
        add_header X-XSS-Protection "1; mode=block" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Content-Security-Policy "default-src 'self' https:; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://zaply.in.net/api wss://zaply.in.net; frame-ancestors 'none';" always;

        # ====================================================================
        # API PROXY - FastAPI backend under /api/ namespace
        # ====================================================================
        location /api/ {
            proxy_pass http://backend_upstream;
            proxy_http_version 1.1;
            
            # Standard proxy headers
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            
            # WebSocket upgrade support (for future use)
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection $connection_upgrade;
            
            # Timeouts for API requests
            proxy_connect_timeout 30s;
            proxy_send_timeout 30s;
            proxy_read_timeout 30s;
            
            # Error handling with retries
            proxy_next_upstream error timeout invalid_header http_502 http_503 http_504;
            proxy_next_upstream_tries 5;
            proxy_next_upstream_timeout 60s;
            
            # Custom error page - use named location for JSON response
            proxy_intercept_errors on;
            error_page 502 503 504 = @backend_fallback;
        }

        # ====================================================================
        # BACKEND FALLBACK - Custom 502/503/504 error responses
        # ====================================================================
        location @backend_fallback {
            internal;
            add_header Content-Type application/json;
            return 502 '{"error": "Backend temporarily unavailable", "status": 502, "retry_after": 30}';
        }

        # ====================================================================
        # ERROR PAGES
        # ====================================================================
        location = /50x.html {
            root /usr/share/nginx/html;
            internal;
        }

        # ====================================================================
        # SECURITY - Block source maps and backup files
        # ====================================================================
        location ~* \.map$ {
            access_log off;
            add_header Content-Type text/plain;
            return 204 "No Content";
        }

        location ~* \.(backup|bak)$ {
            access_log off;
            return 404;
        }

        # ====================================================================
        # SEO FILES - Serve robots.txt and sitemap.xml with headers
        # ====================================================================
        # IMPORTANT: These locations MUST come BEFORE the SPA fallback
        
        location = /robots.txt {
            root /var/www/html;
            add_header Content-Type "text/plain; charset=utf-8" always;
            add_header Cache-Control "public, max-age=86400" always;
            access_log off;
            try_files $uri =404;
        }

        location = /sitemap.xml {
            root /var/www/html;
            add_header Content-Type "application/xml; charset=utf-8" always;
            add_header Cache-Control "public, max-age=604800" always;
            access_log off;
            try_files $uri =404;
        }

        # ====================================================================
        # WEBSOCKET SUPPORT - Real-time messaging
        # ====================================================================
        location /ws/ {
            proxy_pass http://backend_upstream;
            proxy_http_version 1.1;
            
            # WebSocket upgrade headers
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            
            # Standard proxy headers
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            
            # Long-lived WebSocket timeouts
            proxy_read_timeout 3600s;
            proxy_send_timeout 3600s;
            proxy_buffering off;
        }

        # ====================================================================
        # STATIC ASSETS - Cache hashed filenames aggressively
        # ====================================================================
        # Flutter build outputs include content hash in filenames
        # Example: main.a1b2c3d4.js - safe to cache for 1 year
        
        location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
            proxy_pass http://frontend_upstream;
            proxy_http_version 1.1;
            
            # Aggressive caching for immutable assets
            expires 1y;
            add_header Cache-Control "public, immutable, max-age=31536000" always;
            
            # Standard proxy headers
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Connection "";
        }

        # ====================================================================
        # SPA ROUTING - Clean URLs without hash symbols
        # ====================================================================
        # CRITICAL: This location must be LAST (lowest priority)
        # 
        # How it works:
        # 1. Request: /auth
        # 2. Nginx checks for physical file → 404
        # 3. Nginx: error_page 404 = /index.html → serves /index.html
        # 4. Browser: Loads Flutter SPA (main.dart.js)
        # 5. Flutter: GoRouter reads URL → renders AuthScreen
        # 
        # Examples:
        #   /             → index.html → SplashScreen
        #   /auth         → index.html → AuthScreen
        #   /chats        → index.html → ChatListScreen
        #   /chat/123     → index.html → ChatDetailScreen(123)
        #   /settings     → index.html → SettingsScreen
        #   /profile-edit → index.html → ProfileEditScreen
        
        location / {
            # Proxy to frontend container
            proxy_pass http://frontend_upstream;
            proxy_http_version 1.1;
            
            # Standard proxy headers
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Connection "";
            
            # CRITICAL: SPA fallback - serve index.html for 404s
            proxy_intercept_errors on;
            error_page 404 = /index.html;
            
            # Timeout settings
            proxy_connect_timeout 30s;
            proxy_send_timeout 30s;
            proxy_read_timeout 30s;
        }
    }
}

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================
# 
# 1. BUILDING FLUTTER WEB:
#    $ flutter clean
#    $ flutter build web --release
#    Output: frontend/build/web/
# 
# 2. DOCKER DEPLOYMENT:
#    $ docker build -t zaply-frontend:latest frontend/
#    $ docker build -t zaply-backend:latest backend/
#    $ docker-compose up -d
# 
# 3. VERIFYING DEPLOYMENT:
#    $ curl https://zaply.in.net/robots.txt
#    $ curl https://zaply.in.net/sitemap.xml
#    $ curl https://zaply.in.net/auth (should return SPA HTML)
#    $ curl https://zaply.in.net/api/health (should reach backend)
# 
# 4. SSL CERTIFICATE RENEWAL:
#    Let's Encrypt certs auto-renew via Docker
#    Certbot runs in renewal container
#    No manual renewal needed
# 
# ============================================================================
