{
  "CORSRules": [
    {
      "AllowedHeaders": [
        "*"
      ],
      "AllowedMethods": [
        "GET",
        "HEAD",
        "PUT"
      ],
      "AllowedOrigins": [
        "https://zaply.in.net",
        "http://localhost:3000",
        "http://localhost:8080",
        "http://localhost:8000"
      ],
      "ExposeHeaders": [
        "Content-Disposition",
        "Content-Length",
        "Content-Type"
      ],
      "MaxAgeSeconds": 3600
    }
  ]
}
